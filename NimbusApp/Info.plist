<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Google Sign-In URL scheme -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.181444937879-21hnunq53cqk2l2hr3llptjjiarll5qh</string>
			</array>
		</dict>
	</array>

	<!-- API base URL components — set per build configuration via xcconfig.
	     APIClient reconstructs the full URL as $(APIBaseScheme)://$(APIBaseHost). -->
	<key>APIBaseScheme</key>
	<string>$(API_BASE_SCHEME)</string>
	<key>APIBaseHost</key>
	<string>$(API_BASE_HOST)</string>

	<!-- Allow plain HTTP to localhost so the Dev scheme can reach a local server.
	     NSAllowsLocalNetworking is an Apple-sanctioned ATS carve-out that only
	     loosens restrictions for loopback addresses; it has no effect in PROD. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<!-- Opt out of iPad multitasking (Split View / Slide Over).
	     Without this, Apple requires all 4 interface orientations on iPad.
	     This app is portrait-only, so we declare full-screen intent instead. -->
	<key>UIRequiresFullScreen</key>
	<true/>

	<!-- Required to receive remote (push) notifications while the app is in the background -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
